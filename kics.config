# KICS configuration file (repo-root override)
# Overrides the shared template from .mega-linter.d/kics.config.
# Docs: https://docs.kics.io/latest/configuration-file/

# Exclude queries by ID:
# baee238e-1921-4801-9c3f-79ae1d7b2cbc: "Hardcoded secret key"
#   False positive on protobuf pagination fields named page_token / next_page_token.
exclude-queries:
  - "baee238e-1921-4801-9c3f-79ae1d7b2cbc"

# Exclude directories not relevant to infrastructure scanning
exclude-paths:
  - ".cache"
  - ".claude"
  - ".opencode"
  - "custom-flavor"
